{
  "name": "port",
  "private": true,
  "scripts": {
    "dev": "turbo dev --no-daemon",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:port": "turbo dev --filter=nim",
    "dev:burnkit": "turbo dev --filter=@ndos/burnkit",
    "dev:timekit": "turbo dev --filter=@ndos/timekit",
    "dev:sente": "turbo dev --filter=@ndos/sente",
    "dev:memorykit": "turbo dev --filter=@ndos/memorykit"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines"
    ]
  }
}
