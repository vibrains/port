/**
 * Upload Page
 * Main upload page with multi-step wizard for CSV data import
 * @module app/(dashboard)/admin/upload/page
 */

"use client";

import { useState, useCallback } from "react";
import { useRouter } from "next/navigation";
import { DataSource, detectDataSource, detectDataSourceFromContent } from "@/lib/parsers/factory";
import { validateUpload, UploadValidationResult } from "@/lib/validators/upload";
import { parseCSVToRecords } from "@/lib/parsers";
import { Dropzone } from "@/components/upload/dropzone";
import { SourceCards } from "@/components/upload/source-selector";
import { UploadPreview } from "@/components/upload/upload-preview";
import { ProgressIndicator, UploadSuccess, UploadError } from "@/components/upload/progress-indicator";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Alert, AlertDescription } from "@/components/ui/alert";
import { Separator } from "@/components/ui/separator";
import { Upload, ArrowLeft, FileText, AlertCircle } from "lucide-react";

/**
 * Upload step types
 */
type UploadStep = "select" | "preview" | "uploading" | "result";

/**
 * Upload result type
 */
interface UploadResult {
  success: boolean;
  uploadId?: string;
  rowCount?: number;
  message?: string;
  errors?: string[];
}

/**
 * Upload Page component
 * Multi-step wizard for uploading CSV data files
 */
export default function UploadPage() {
  const router = useRouter();
  
  // State
  const [currentStep, setCurrentStep] = useState<UploadStep>("select");
  const [selectedFile, setSelectedFile] = useState<File | null>(null);
  const [sourceType, setSourceType] = useState<DataSource | null>(null);
  const [detectedSource, setDetectedSource] = useState<DataSource | null>(null);
  const [parsedData, setParsedData] = useState<{
    headers: string[];
    rows: Record<string, string>[];
    rowCount: number;
  } | null>(null);
  const [validationResult, setValidationResult] = useState<UploadValidationResult | null>(null);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [uploadStatus, setUploadStatus] = useState<"idle" | "validating" | "parsing" | "uploading" | "processing" | "completed" | "error">("idle");
  const [uploadResult, setUploadResult] = useState<UploadResult | null>(null);
  const [error, setError] = useState<string | null>(null);

  /**
   * Handles file selection from dropzone
   */
  const handleFilesAccepted = useCallback(async (files: File[]) => {
    if (files.length === 0) return;
    
    const file = files[0];
    setSelectedFile(file);
    setError(null);

    // Detect source from filename
    const fromFilename = detectDataSource(file.name);
    if (fromFilename) {
      setDetectedSource(fromFilename);
      setSourceType(fromFilename);
    }
  }, []);

  /**
   * Validates the selected file and moves to preview step
   */
  const handleValidateFile = useCallback(async () => {
    if (!selectedFile) return;

    setUploadStatus("validating");
    setUploadProgress(10);

    try {
      // Read file content
      const csvContent = await selectedFile.text();
      
      setUploadStatus("parsing");
      setUploadProgress(30);

      // Detect source from content if not already detected
      let finalSourceType = sourceType;
      if (!finalSourceType) {
        const fromContent = detectDataSourceFromContent(csvContent);
        if (fromContent) {
          setDetectedSource(fromContent);
          setSourceType(fromContent);
          finalSourceType = fromContent;
        }
      }

      // Parse CSV for preview
      const records = parseCSVToRecords(csvContent);
      const headers = Object.keys(records[0] || {});
      
      setParsedData({
        headers,
        rows: records,
        rowCount: records.length,
      });

      setUploadProgress(50);

      // Validate the upload
      const validation = await validateUpload(selectedFile, finalSourceType || undefined);
      setValidationResult(validation);

      setUploadProgress(100);
      setUploadStatus("idle");
      setCurrentStep("preview");
    } catch (err) {
      setError(err instanceof Error ? err.message : "Failed to validate file");
      setUploadStatus("error");
    }
  }, [selectedFile, sourceType]);

  /**
   * Handles the actual file upload
   */
  const handleUpload = useCallback(async () => {
    if (!selectedFile || !sourceType) return;

    setCurrentStep("uploading");
    setUploadStatus("uploading");
    setUploadProgress(0);

    try {
      const formData = new FormData();
      formData.append("file", selectedFile);
      formData.append("sourceType", sourceType);

      // Simulate progress updates
      const progressInterval = setInterval(() => {
        setUploadProgress((prev) => {
          if (prev >= 90) {
            clearInterval(progressInterval);
            return 90;
          }
          return prev + 10;
        });
      }, 500);

      const response = await fetch("/api/upload", {
        method: "POST",
        body: formData,
      });

      clearInterval(progressInterval);

      const result = await response.json();

      if (!response.ok) {
        setUploadResult({
          success: false,
          message: result.error || "Upload failed",
          errors: result.errors || [],
        });
        setUploadStatus("error");
      } else {
        setUploadResult({
          success: true,
          uploadId: result.uploadId,
          rowCount: result.inserted,
          message: `Successfully uploaded ${result.inserted} rows`,
        });
        setUploadStatus("completed");
      }

      setUploadProgress(100);
      setCurrentStep("result");
    } catch (err) {
      setUploadResult({
        success: false,
        message: err instanceof Error ? err.message : "Upload failed",
      });
      setUploadStatus("error");
      setCurrentStep("result");
    }
  }, [selectedFile, sourceType]);

  /**
   * Resets the form to upload another file
   */
  const handleReset = useCallback(() => {
    setCurrentStep("select");
    setSelectedFile(null);
    setSourceType(null);
    setDetectedSource(null);
    setParsedData(null);
    setValidationResult(null);
    setUploadProgress(0);
    setUploadStatus("idle");
    setUploadResult(null);
    setError(null);
  }, []);

  /**
   * Goes back to the previous step
   */
  const handleBack = useCallback(() => {
    if (currentStep === "preview") {
      setCurrentStep("select");
      setParsedData(null);
      setValidationResult(null);
    } else if (currentStep === "result") {
      setCurrentStep("preview");
    }
  }, [currentStep]);

  return (
    <div className="space-y-6">
      {/* Header */}
      <div>
        <h1 className="text-2xl font-bold flex items-center gap-2">
          <Upload className="w-6 h-6" />
          Upload Data
        </h1>
        <p className="text-muted-foreground mt-1">
          Import marketing data from CSV files
        </p>
      </div>

      <Separator />

      {/* Step 1: File Selection */}
      {currentStep === "select" && (
        <div className="space-y-6">
          <Card>
            <CardHeader>
              <CardTitle className="text-base">Select Data Source</CardTitle>
              <CardDescription>
                Choose the type of data you're uploading
              </CardDescription>
            </CardHeader>
            <CardContent>
              <SourceCards
                value={sourceType}
                onChange={setSourceType}
                detectedSource={detectedSource}
              />
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <CardTitle className="text-base">Upload File</CardTitle>
              <CardDescription>
                Drag and drop your CSV file or click to browse
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              <Dropzone
                onFilesAccepted={handleFilesAccepted}
                accept=".csv"
                maxSize={50 * 1024 * 1024}
              />

              {error && (
                <Alert variant="destructive">
                  <AlertCircle className="w-4 h-4" />
                  <AlertDescription>{error}</AlertDescription>
                </Alert>
              )}

              {selectedFile && (
                <div className="flex items-center justify-between p-3 bg-muted rounded-lg">
                  <div className="flex items-center gap-2">
                    <FileText className="w-4 h-4 text-muted-foreground" />
                    <span className="text-sm font-medium">{selectedFile.name}</span>
                    <span className="text-xs text-muted-foreground">
                      ({(selectedFile.size / 1024 / 1024).toFixed(2)} MB)
                    </span>
                  </div>
                  <Button
                    onClick={handleValidateFile}
                    disabled={!sourceType}
                  >
                    Continue
                  </Button>
                </div>
              )}

              {!selectedFile && !sourceType && (
                <Alert>
                  <AlertCircle className="w-4 h-4" />
                  <AlertDescription>
                    Please select a data source type and upload a CSV file to continue
                  </AlertDescription>
                </Alert>
              )}
            </CardContent>
          </Card>
        </div>
      )}

      {/* Step 2: Preview */}
      {currentStep === "preview" && selectedFile && parsedData && validationResult && (
        <div className="space-y-4">
          <div className="flex items-center gap-2">
            <Button variant="outline" size="sm" onClick={handleBack}>
              <ArrowLeft className="w-4 h-4 mr-1" />
              Back
            </Button>
            <span className="text-sm text-muted-foreground">Step 2 of 3: Preview</span>
          </div>

          <UploadPreview
            file={selectedFile}
            parsedData={parsedData}
            validationResult={validationResult}
            onConfirm={handleUpload}
            onCancel={handleBack}
            isUploading={false}
          />
        </div>
      )}

      {/* Step 3: Uploading */}
      {currentStep === "uploading" && (
        <Card className="py-12">
          <CardContent className="max-w-md mx-auto">
            <ProgressIndicator
              progress={uploadProgress}
              status={uploadStatus}
              message={
                uploadStatus === "uploading"
                  ? "Uploading file to server..."
                  : uploadStatus === "processing"
                  ? "Processing data..."
                  : undefined
              }
            />
          </CardContent>
        </Card>
      )}

      {/* Step 4: Result */}
      {currentStep === "result" && uploadResult && (
        <Card className="py-8">
          <CardContent>
            {uploadResult.success ? (
              <UploadSuccess
                rowCount={uploadResult.rowCount || 0}
                message={uploadResult.message}
                onUploadAnother={handleReset}
                onViewHistory={() => router.push("/admin/uploads")}
              />
            ) : (
              <UploadError
                message={uploadResult.message || "Upload failed"}
                onRetry={handleUpload}
                onBack={handleBack}
              />
            )}
          </CardContent>
        </Card>
      )}
    </div>
  );
}
