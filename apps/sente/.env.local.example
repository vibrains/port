# Database (Sevalla provides this for connected PostgreSQL databases)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-min-32-characters-long
NEXTAUTH_URL=http://localhost:3000

# Admin users (comma-separated emails with admin access)
# Default admin: admin@sente.com (password: any non-empty string for MVP)
ADMIN_USERS=admin@sente.com,admin@nearanddear.com

# Anthropic API key (required for AI Insights feature)
ANTHROPIC_API_KEY=sk-ant-...
