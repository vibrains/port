// Teamwork Time Log Web App - Database Schema
// Backend Lead Agent - Phase 1 Implementation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Company model - Stores companies from Teamwork
model Company {
  id                 String    @id @default(uuid())
  teamworkCompanyId  Int       @unique @map("teamwork_company_id")
  name               String
  users              User[]
  projects           Project[]
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([name])
  @@map("companies")
}

// User model - Stores export configuration for employees
// Note: Authentication is handled by Auth.js, not this table
// This table is used by finance team to manage export settings
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  googleId       String   @unique @map("google_id")
  companyId      String?  @map("company_id")

  // Export settings (for fixed-width export file)
  employeeCode        String?  @map("employee_code") @db.VarChar(6)
  departmentCode      String?  @map("department_code") @db.VarChar(4)
  fncCode             String?  @map("fnc_code") @db.VarChar(10)

  // Soft delete - preserves historical data
  deletedAt      DateTime? @map("deleted_at")

  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  timeLogs       TimeLog[]
  exports        Export[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([deletedAt])
  @@index([email, deletedAt])
  @@map("users")
}

// Project model - Stores projects synced from Teamwork
model Project {
  id                String   @id @default(uuid())
  teamworkProjectId Int      @unique @map("teamwork_project_id")
  name              String
  jobCode           String?  @map("job_code") @db.VarChar(30)
  companyId         String?  @map("company_id")

  company           Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  timeLogs          TimeLog[]
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([name])
  @@map("projects")
}

// TimeLog model - Stores time log entries synced from Teamwork
// approvalStatus: 'approved' | 'inreview' | 'needschanges' | null (not in approval workflow)
model TimeLog {
  id             String   @id @default(uuid())
  teamworkLogId  Int      @unique @map("teamwork_log_id")
  userId         String   @map("user_id")
  projectId      String   @map("project_id")
  date           DateTime @db.Date
  minutes        Int
  description    String?  @db.Text
  jobNumber      String?  @map("job_number") @db.VarChar(30)
  approvalStatus String?  @map("approval_status") @db.VarChar(20)
  billable       Boolean  @default(false) @map("is_billable")
  syncedAt       DateTime @map("synced_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Soft delete - set when record is deleted in Teamwork
  deletedAt      DateTime? @map("deleted_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([date, userId, projectId])
  @@index([userId, date], map: "time_logs_user_date_idx")
  @@index([projectId, date], map: "time_logs_project_date_idx")
  @@index([approvalStatus, date])
  @@index([approvalStatus, date, userId], map: "time_logs_approval_date_user_idx")
  @@index([syncedAt])
  @@index([deletedAt])
  @@map("time_logs")
}

model TaskJobNumberCache {
  id         String   @id @default(uuid())
  taskId     Int      @unique @map("task_id")
  jobNumber  String?  @map("job_number") @db.VarChar(30)
  fetchedAt  DateTime @default(now()) @map("fetched_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([fetchedAt])
  @@map("task_job_number_cache")
}

model ProjectJobNumberCache {
  id         String   @id @default(uuid())
  projectId  Int      @unique @map("project_id")
  jobNumber  String?  @map("job_number") @db.VarChar(30)
  fetchedAt  DateTime @default(now()) @map("fetched_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([fetchedAt])
  @@map("project_job_number_cache")
}

// Export model - Stores export file metadata
model Export {
  id             String   @id @default(uuid())
  fileName       String   @map("file_name")
  s3Key          String   @unique @map("s3_key")
  dateRangeStart DateTime @db.Date @map("date_range_start")
  dateRangeEnd   DateTime @db.Date @map("date_range_end")
  isQuickRun     Boolean  @default(false) @map("is_quick_run")
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")

  creator        User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy, createdAt])
  @@index([expiresAt])
  @@map("exports")
}
