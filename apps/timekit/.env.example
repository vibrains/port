# Environment Variables Template
# Backend Lead Agent & DevOps Agent - Phase 1
#
# Copy this file to .env and fill in the values

# Database Configuration
# Sevalla PostgreSQL connection string
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Auth.js Configuration
# Base URL of the application (use https://ndos-timekit.kinsta.app for production)
NEXTAUTH_URL="http://localhost:3000"
# Random secret for JWT signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Google OAuth Configuration
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Optional: Restrict to specific Google Workspace domains (comma-separated)
GOOGLE_WORKSPACE_DOMAINS="domain1.com,domain2.com"
# Optional: Enable detailed OAuth debug logging (set to "true" to enable)
OAUTH_DEBUG="false"

# Development Authentication Bypass (ONLY works in NODE_ENV=development)
# Optional: Custom email for dev bypass user
DEV_BYPASS_EMAIL="dev@localhost"
# Optional: Custom name for dev bypass user
DEV_BYPASS_NAME="Dev User"

# Teamwork API Configuration
# Get API key from Teamwork account settings
TEAMWORK_API_KEY="your-teamwork-api-key"
# Your Teamwork site name (e.g., if URL is yoursite.teamwork.com, use "yoursite")
TEAMWORK_SITE_NAME="your-site-name"
# Custom field IDs for "Adv Job #" (find using scripts/find-custom-field.ts)
TEAMWORK_JOB_NUMBER_TASK_FIELD_ID="76378"
TEAMWORK_JOB_NUMBER_PROJECT_FIELD_ID="76153"

# Cloudflare R2 Object Storage Configuration (S3-Compatible)
# Get these from Cloudflare R2 dashboard
S3_ENDPOINT="https://c7e106846fa0e461a139e5384b27bb6c.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="ndostimekit-exports-73gul"
# Optional: Region (default: auto)
S3_REGION="auto"

# Cron Service Authentication
# Random key for securing the sync endpoint (generate with: openssl rand -base64 32)
CRON_API_KEY="your-cron-api-key"

# Timezone Configuration
# Application timezone for date/time display and filtering (IANA timezone identifier)
TZ="America/Los_Angeles"

# Optional: Node Environment
NODE_ENV="development"
